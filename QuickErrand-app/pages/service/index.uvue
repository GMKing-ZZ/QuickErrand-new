  opacity: 1;
}

.service-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%);
  border-radius: 24rpx;
}

.service-icon {
  font-size: 80rpx;
  line-height: 1;
}

.service-icon-image {
  width: 100%;
