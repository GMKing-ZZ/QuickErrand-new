}

.map-card {
  background: var(--list-background-color, #ffffff);
  border-radius: 20rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-map {
  width: 100%;
  height: 450rpx;
}

.map-legend {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  gap: 30rpx;
  background: var(--list-background-color, #ffffff);
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
