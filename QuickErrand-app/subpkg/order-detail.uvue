<template>
  <view class="order-detail-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">订单详情</text>
      <view class="placeholder"></view>
    </view>

    <!-- 可滚动内容区域 -->
    <scroll-view class="content-scroll" scroll-y enable-back-to-top>
      <!-- 订单状态 -->
      <view class="status-section">
        <view class="status-row">
          <text class="status-badge" :class="'s' + orderInfo.status">
            {{ orderInfo.statusText || getStatusText(orderInfo.status) }}
          </text>
          <text class="status-amount">¥{{ formatMoney(orderInfo.amount) }}</text>
        </view>
        <!-- 费用明细：配送费 + 平台服务费 -->
        <view class="fee-row">
          <text class="fee-item">
            配送费：
            <text class="fee-amount">¥{{ formatMoney(orderInfo.runnerFee ?? 0) }}</text>
          </text>
          <text class="fee-item">
            平台服务费：
            <text class="fee-amount">¥{{ formatMoney(orderInfo.platformFee ?? 0) }}</text>
          </text>
        </view>
        <text class="status-sub">{{ orderInfo.orderNo }}</text>
        <text class="status-tip">{{ getStatusTip() }}</text>
        
        <!-- 订单进度条（已取消状态不显示） -->
        <view v-if="orderInfo.status !== 5" class="progress-bar">
          <view class="progress-container">
            <view class="progress-track">
              <view class="progress-fill" :style="{ width: getProgressWidth() }"></view>
            </view>
            <view class="progress-nodes">
              <view 
                v-for="(step, index) in progressSteps" 
                :key="index"
                class="progress-node"
                :class="{ active: isStepActive(index), current: isStepCurrent(index) }"
              >
                <view class="node-dot">
                  <text v-if="isStepActive(index)" class="node-check">✓</text>
                </view>
                <text class="node-label">{{ step.label }}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 收货码（仅订单创建者可见） -->
      <view v-if="shouldShowPickupCode" class="pickup-code-section">
        <view class="code-card">
          <text class="code-label">收货码</text>
          <text class="code-value">{{ orderInfo.pickupCode }}</text>
          <text class="code-tip">请将此码告知跑腿员以完成订单</text>
        </view>
      </view>

      <!-- 地址信息（优先展示“去哪儿”） -->
      <view class="address-section">
        <view class="section-title">
          <text class="title-icon">📍</text>
          <text class="title-text">地址信息</text>
        </view>
        <view class="address-card">
          <view class="address-item">
            <view class="address-label">
              <text class="label-icon">🔵</text>
              <text class="label-text">取件地址</text>
            </view>
            <view class="address-content">
              <text class="address-line">
                取件人：<text class="address-line-value">{{ orderInfo.pickupContact }}</text>
              </text>
              <text class="address-line">
                取件联系：<text class="address-line-value">{{ orderInfo.pickupPhone }}</text>
              </text>
              <text class="address-line">
                取件地址：<text class="address-line-value">{{ orderInfo.pickupAddress }}</text>
              </text>
            </view>
          </view>
          <view class="address-divider"></view>
          <view class="address-item">
            <view class="address-label">
              <text class="label-icon">🔴</text>
              <text class="label-text">送达地址</text>
            </view>
            <view class="address-content">
              <text class="address-line">
                收件人：<text class="address-line-value">{{ orderInfo.deliveryContact }}</text>
              </text>
              <text class="address-line">
                联系电话：<text class="address-line-value">{{ orderInfo.deliveryPhone }}</text>
              </text>
              <text class="address-line">
                送达地址：<text class="address-line-value">{{ orderInfo.deliveryAddress }}</text>
              </text>
            </view>
          </view>
        </view>
      </view>

      <!-- 地图路线展示 -->
      <view v-if="hasValidCoordinates" class="map-section">
        <view class="section-title">
          <text class="title-icon">🗺️</text>
          <text class="title-text">路线地图</text>
        </view>
        <view class="map-card">
          <map
            id="orderMap"
            :latitude="mapCenter.latitude"
            :longitude="mapCenter.longitude"
            :scale="mapScale"
            :markers="mapMarkers"
            :polyline="mapPolyline"
            :show-location="false"
            :enable-zoom="true"
            :enable-scroll="true"
            :enable-rotate="false"
            class="order-map"
            @markertap="onMarkerTap"
          ></map>
          <view class="map-legend">
            <view class="legend-item">
              <view class="legend-dot legend-dot-pickup"></view>
              <text class="legend-text">取件点</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot legend-dot-delivery"></view>
              <text class="legend-text">送达点</text>
            </view>
            <view class="legend-item" v-if="orderInfo.distance && orderInfo.distance > 0">
              <text class="legend-distance">配送 {{ formatDistance(orderInfo.distance) }} km</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 物品信息（描述/图片） -->
      <view v-if="orderInfo.itemDescription || imageList.length" class="item-section">
        <view class="section-title">
          <text class="title-icon">🧾</text>
          <text class="title-text">物品信息</text>
        </view>
        <view class="item-card">
          <text v-if="orderInfo.itemDescription" class="item-desc">{{ orderInfo.itemDescription }}</text>

          <scroll-view v-if="imageList.length" class="image-scroll" scroll-x>
            <view class="image-row">
              <image
                v-for="(url, idx) in imageList"
                :key="idx"
                class="item-image"
                :src="url"
                mode="aspectFill"
                @click="previewImages(idx)"
              />
            </view>
          </scroll-view>
        </view>
      </view>

      <!-- 跑腿员信息 -->
      <view v-if="orderInfo.runnerId" class="runner-section">
        <view class="section-title">
          <text class="title-icon">👤</text>
          <text class="title-text">跑腿员信息</text>
        </view>
        <view class="runner-card" @click="goRunnerProfile">
          <text class="info-line">
            跑腿员姓名：<text class="info-line-value">{{ orderInfo.runnerName }}</text>
          </text>
          <text class="info-line">
            联系电话：<text class="info-line-value">{{ orderInfo.runnerPhone }}</text>
          </text>
          <view class="runner-card-hint">
            <text class="hint-text">点击查看跑腿员详情</text>
            <text class="hint-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 订单信息（含费用） -->
      <view class="order-info-section">
        <view class="section-title">
          <text class="title-icon">📋</text>
          <text class="title-text">订单信息</text>
        </view>
        <view class="info-card">
          <text class="info-line">
            订单编号：<text class="info-line-value">{{ orderInfo.orderNo }}</text>
          </text>
          <text class="info-line">
            订单类型：<text class="info-line-value">{{ orderInfo.orderTypeName }}</text>
          </text>
          <text class="info-line">
            下单时间：<text class="info-line-value">{{ formatTime(orderInfo.createTime) }}</text>
          </text>
          <text v-if="orderInfo.paymentTime" class="info-line">
            支付时间：<text class="info-line-value">{{ formatTime(orderInfo.paymentTime) }}</text>
          </text>
          <text class="info-line">
            配送距离：<text class="info-line-value">{{ formatDistance(orderInfo.distance) }} km</text>
          </text>
          <text class="info-line">
            支付方式：<text class="info-line-value">{{ getPaymentMethodText() }}</text>
          </text>
          <text class="info-line">
            配送费：
            <text class="info-line-value">¥{{ formatMoney(orderInfo.runnerFee ?? 0) }}</text>
          </text>
          <text class="info-line">
            平台服务费：
            <text class="info-line-value">¥{{ formatMoney(orderInfo.platformFee ?? 0) }}</text>
          </text>
          <text class="info-line info-line-amount">
            实付金额：<text class="info-line-amount-value">¥{{ formatMoney(orderInfo.amount) }}</text>
          </text>
        </view>
      </view>

      <!-- 评价信息（如已评价） -->
      <view v-if="orderInfo.evaluated" class="evaluation-section">
        <view class="section-title">
          <text class="title-icon">💬</text>
          <text class="title-text">订单评价</text>
        </view>
        <view class="evaluation-card">
          <!-- 星级横向展示，两行：服务质量 / 服务态度 -->
          <view class="eval-star-rows">
            <view class="eval-star-row">
              <text class="eval-star-label">服务质量</text>
              <view class="eval-star-list">
                <text
                  v-for="n in 5"
                  :key="`service-${n}`"
                  class="eval-star"
                  :class="{ active: n <= (orderInfo.serviceScore || 0) }"
                >
                  ★
                </text>
              </view>
              <text class="eval-star-score">{{ orderInfo.serviceScore || 0 }}分</text>
            </view>
            <view class="eval-star-row" v-if="orderInfo.attitudeScore !== undefined && orderInfo.attitudeScore !== null">
              <text class="eval-star-label">服务态度</text>
              <view class="eval-star-list">
                <text
                  v-for="n in 5"
                  :key="`attitude-${n}`"
                  class="eval-star"
                  :class="{ active: n <= (orderInfo.attitudeScore || 0) }"
                >
                  ★
                </text>
              </view>
              <text class="eval-star-score">{{ orderInfo.attitudeScore || 0 }}分</text>
            </view>
          </view>

          <!-- 评价内容 -->
          <text class="evaluation-content">
            {{ orderInfo.evaluationContent || '用户未填写具体评价内容' }}
          </text>

          <!-- 评价图片（如有） -->
          <scroll-view
            v-if="evaluationImageList.length"
            class="evaluation-image-scroll"
            scroll-x
          >
            <view class="evaluation-image-row">
              <image
                v-for="(url, idx) in evaluationImageList"
                :key="idx"
                class="evaluation-image"
                :src="url"
                mode="aspectFill"
                @click="previewEvaluationImages(idx)"
              />
            </view>
          </scroll-view>
        </view>
      </view>

      <!-- 备注信息 -->
      <view v-if="orderInfo.remark" class="remark-section">
        <view class="section-title">
          <text class="title-icon">📝</text>
          <text class="title-text">备注信息</text>
        </view>
        <view class="remark-card">
          <text class="remark-text">{{ orderInfo.remark }}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作按钮 -->
    <view v-if="showActionButtons || showContactRunnerButton" class="action-section">
      <!-- 下单用户的按钮：支付和取消 -->
      <template v-if="!isRunner">
        <button
          v-if="orderInfo.status === 1"
          class="action-btn pay-btn"
          @click="handlePay"
        >
          <text class="btn-text">立即支付</text>
        </button>
        <button
          v-if="orderInfo.status === 4 && isOrderOwner && !orderInfo.evaluated"
          class="action-btn contact-runner-btn"
          @click="goEvaluateFromDetail"
        >
          <text class="btn-text">评价订单</text>
        </button>
        <button
          v-if="(orderInfo.status === 1 || orderInfo.status === 2) && isOrderOwner"
          class="action-btn cancel-btn"
          @click="handleCancel"
        >
          <text class="btn-text">取消订单</text>
        </button>
        <!-- 联系跑腿员按钮（仅订单所有者且订单已接单时显示） -->
        <button
          v-if="showContactRunnerButton"
          class="action-btn contact-runner-btn"
          @click="handleContactRunner"
        >
          <text class="btn-text">联系跑腿员</text>
        </button>
      </template>
      <!-- 跑腿员的按钮：立即接单 / 确认收货 -->
      <template v-else>
        <!-- 拉黑提示 -->
        <view v-if="orderInfo.status === 2 && orderInfo.blacklisted" class="blacklist-tip">
          <text class="blacklist-tip-icon">⚠️</text>
          <text class="blacklist-tip-text">您已被该用户拉黑，无法接此订单</text>
        </view>
        <button
          v-if="orderInfo.status === 2"
          class="action-btn accept-btn"
          :class="{ 'disabled-btn': orderInfo.blacklisted }"
          :disabled="orderInfo.blacklisted"
          @click="handleAcceptOrder"
        >
          <text class="btn-text">{{ orderInfo.blacklisted ? '无法接单' : '立即接单' }}</text>
        </button>
        <button
          v-if="orderInfo.status === 3 && isOrderRunner"
          class="action-btn confirm-receive-btn"
          @click="goConfirmReceive"
        >
          <text class="btn-text">确认收货</text>
        </button>
      </template>
    </view>

    <!-- 联系方式选择弹窗 -->
    <view v-if="showContactModal" class="modal-mask" @click="closeContactModal">
      <view class="modal-content" @click.stop>
        <view class="modal-header">
          <text class="modal-title">选择联系方式</text>
          <view class="modal-close" @click="closeContactModal">
            <text class="close-icon">×</text>
          </view>
        </view>
        <view class="modal-body">
          <view class="contact-option" @click="handleOnlineContact">
            <text class="option-icon">💬</text>
            <text class="option-text">在线联系（推荐）</text>
            <text class="option-arrow">›</text>
          </view>
          <view class="contact-option" @click="handlePhoneContact">
            <text class="option-icon">📞</text>
            <text class="option-text">电话联系</text>
            <text class="option-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 电话号码弹窗 -->
    <view v-if="showPhoneModal" class="modal-mask" @click="closePhoneModal">
      <view class="modal-content phone-modal-content" @click.stop>
        <view class="modal-header">
          <text class="modal-title">跑腿员电话</text>
          <view class="modal-close" @click="closePhoneModal">
            <text class="close-icon">×</text>
          </view>
        </view>
        <view class="modal-body">
          <text class="phone-number">{{ orderInfo.runnerPhone }}</text>
          <button class="call-btn" @click="callRunner">
            <text class="call-btn-text">拨打</text>
          </button>
        </view>
      </view>
    </view>
  </view>
</template>

<script>
import { getOrderDetail, payOrder, cancelOrder } from '@/common/api/order.uts'
import type { OrderInfo } from '@/common/api/order.uts'
import { userState, checkIsRunner } from '@/store/user.uts'
import { acceptOrder, getRunnerAuthInfo } from '@/common/api/runner.uts'
import { MAP_CONFIG } from '@/common/config/map.uts'

export default {
  data() {
    return {
      orderId: 0,
      loading: false,
      showContactModal: false,
      showPhoneModal: false,
      mapScale: 13,
      routePoints: [] as Array<{ latitude: number; longitude: number }>,
      orderInfo: {
        id: 0,
        orderNo: '',
        userId: 0,
        orderTypeId: 0,
        orderTypeName: '',
        pickupAddressId: 0,
        deliveryAddressId: 0,
        pickupContact: '',
        pickupPhone: '',
        pickupAddress: '',
        pickupLongitude: '',
        pickupLatitude: '',
        deliveryContact: '',
        deliveryPhone: '',
        deliveryAddress: '',
        deliveryLongitude: '',
        deliveryLatitude: '',
        distance: 0,
        amount: 0,
        itemDescription: '',
        itemImages: '',
        remark: '',
        pickupCode: '',
        status: 0,
        statusText: '',
        runnerId: 0,
        runnerName: '',
        runnerPhone: '',
        paymentMethod: 1,
        paymentTime: '',
        transactionId: '',
        createTime: ''
      } as OrderInfo
    }
  },
  computed: {
    imageList(): string[] {
      const raw: any = (this.orderInfo as any).itemImages
      if (!raw) return []
      if (Array.isArray(raw)) return raw.filter(Boolean)
      const s = String(raw).trim()
      if (!s) return []
      try {
        const parsed = JSON.parse(s)
        if (Array.isArray(parsed)) {
          return parsed.map(v => String(v)).filter(v => !!v && v !== 'null' && v !== 'undefined')
        }
      } catch (e) {
        // ignore
      }
      // 兼容逗号分隔
      return s
        .split(',')
        .map(v => v.trim())
        .filter(v => !!v && v !== 'null' && v !== 'undefined')
    },
    // 评价图片列表（从 orderInfo.evaluationImages 解析）
    evaluationImageList(): string[] {
      const raw: any = (this.orderInfo as any).evaluationImages
      if (!raw) return []
      if (Array.isArray(raw)) return raw.filter(Boolean)
      const s = String(raw).trim()
      if (!s) return []
      try {
        const parsed = JSON.parse(s)
        if (Array.isArray(parsed)) {
          return parsed.map(v => String(v)).filter(v => !!v && v !== 'null' && v !== 'undefined')
        }
      } catch (e) {
        // ignore
      }
      // 兼容逗号分隔
      return s
        .split(',')
        .map(v => v.trim())
        .filter(v => !!v && v !== 'null' && v !== 'undefined')
    },
    // 判断是否是跑腿员
    isRunner(): boolean {
      return checkIsRunner()
    },
    // 判断是否是订单的下单用户
    isOrderOwner(): boolean {
      const currentUserId = userState.userInfo?.id
      return currentUserId !== null && currentUserId !== undefined && this.orderInfo.userId === currentUserId
    },
    // 是否显示收货码：仅订单创建者可见，在待取件、配送中、已完成时显示
    shouldShowPickupCode(): boolean {
      if (!this.orderInfo.pickupCode) return false
      // 跑腿员不显示收货码
      if (this.isRunner) return false
      // 只有订单创建者才能看到收货码，且在待取件、配送中、已完成时显示
      return this.isOrderOwner && this.orderInfo.status >= 2 && this.orderInfo.status <= 4
    },
    // 是否显示底部操作按钮
    showActionButtons(): boolean {
      if (this.isRunner) {
        // 跑腿员：待接单或服务中状态显示操作按钮
        return this.orderInfo.status === 2 || this.orderInfo.status === 3
      } else {
        // 下单用户：待支付或待接单状态显示支付/取消按钮
        return (this.orderInfo.status === 1 || this.orderInfo.status === 2) && this.isOrderOwner
      }
    },
    // 是否显示联系跑腿员按钮
    // 仅订单创建者在「服务中」状态（status === 3）且订单已分配跑腿员时显示
    showContactRunnerButton(): boolean {
      return (
        !this.isRunner && // 不是以跑腿员身份查看
        this.isOrderOwner && // 当前用户为下单人
        !!this.orderInfo.runnerId && // 已有接单跑腿员
        this.orderInfo.status === 3 // 订单处于服务中
      )
    },
    // 当前登录用户是否为该订单的跑腿员
    isOrderRunner(): boolean {
      const currentUserId = userState.userInfo?.id
      return currentUserId !== null && currentUserId !== undefined && this.orderInfo.runnerId === currentUserId
    },
    // 进度条步骤
    progressSteps(): Array<{ label: string; status: number }> {
      return [
        { label: '待支付', status: 1 },
        { label: '待接单', status: 2 },
        { label: '服务中', status: 3 },
        { label: '已完成', status: 4 }
      ]
    },
    hasValidCoordinates(): boolean {
      const pLat = parseFloat(this.orderInfo.pickupLatitude || '')
      const pLng = parseFloat(this.orderInfo.pickupLongitude || '')
      const dLat = parseFloat(this.orderInfo.deliveryLatitude || '')
      const dLng = parseFloat(this.orderInfo.deliveryLongitude || '')
      return !isNaN(pLat) && !isNaN(pLng) && !isNaN(dLat) && !isNaN(dLng)
        && pLat !== 0 && pLng !== 0 && dLat !== 0 && dLng !== 0
    },
    pickupLat(): number {
      return parseFloat(this.orderInfo.pickupLatitude || '0') || 0
    },
    pickupLng(): number {
      return parseFloat(this.orderInfo.pickupLongitude || '0') || 0
    },
    deliveryLat(): number {
      return parseFloat(this.orderInfo.deliveryLatitude || '0') || 0
    },
    deliveryLng(): number {
      return parseFloat(this.orderInfo.deliveryLongitude || '0') || 0
    },
    mapCenter(): { latitude: number; longitude: number } {
      if (!this.hasValidCoordinates) {
        return { latitude: 39.908823, longitude: 116.397470 }
      }
      return {
        latitude: (this.pickupLat + this.deliveryLat) / 2,
        longitude: (this.pickupLng + this.deliveryLng) / 2
      }
    },
    mapMarkers(): any[] {
      if (!this.hasValidCoordinates) return []
      return [
        {
          id: 1,
          latitude: this.pickupLat,
          longitude: this.pickupLng,
          title: '取件点',
          iconPath: '/static/icons/daiqu.png',
          width: 28,
          height: 28,
          callout: {
            content: this.orderInfo.pickupAddress || '取件点',
            display: 'ALWAYS',
            color: '#ffffff',
            bgColor: '#2563eb',
            borderRadius: 8,
            padding: 8,
            fontSize: 12
          }
        },
        {
          id: 2,
          latitude: this.deliveryLat,
          longitude: this.deliveryLng,
          title: '送达点',
          iconPath: '/static/icons/daisong.png',
          width: 28,
          height: 28,
          callout: {
            content: this.orderInfo.deliveryAddress || '送达点',
            display: 'ALWAYS',
            color: '#ffffff',
            bgColor: '#ef4444',
            borderRadius: 8,
            padding: 8,
            fontSize: 12
          }
        }
      ]
    },
    mapPolyline(): any[] {
      if (this.routePoints.length >= 2) {
        return [{
          points: this.routePoints,
          color: '#2563eb',
          width: 6,
          dottedLine: false,
          arrowLine: true,
          borderColor: '#1d4ed8',
          borderWidth: 2
        }]
      }
      if (!this.hasValidCoordinates) return []
      return [{
        points: [
          { latitude: this.pickupLat, longitude: this.pickupLng },
          { latitude: this.deliveryLat, longitude: this.deliveryLng }
        ],
        color: '#2563eb',
        width: 5,
        dottedLine: true,
        arrowLine: true,
        borderColor: '#93c5fd',
        borderWidth: 1
      }]
    }
  },
  onLoad(options) {
    if (options.orderId) {
      this.orderId = parseInt(options.orderId)
      this.loadOrderDetail()
    } else {
      uni.showToast({
        title: '订单ID缺失',
        icon: 'none'
      })
    }
  },
  methods: {
    async loadOrderDetail() {
      try {
        this.loading = true
        const res = await getOrderDetail(this.orderId)
        this.orderInfo = res
        if (this.hasValidCoordinates) {
          this.fetchRoute()
          this.fitMapView()
        }
      } catch (error) {
        console.error('获取订单详情失败:', error)
        uni.showToast({
          title: '加载失败',
          icon: 'none'
        })
      } finally {
        this.loading = false
      }
    },

    goBack() {
      uni.navigateBack()
    },

    getStatusText(status: number): string {
      switch (status) {
        case 1:
          return '待支付'
        case 2:
          return '待接单'
        case 3:
          return '服务中'
        case 4:
          return '已完成'
        case 5:
          return '已取消'
        default:
          return '未知状态'
      }
    },

    getStatusTip(): string {
      switch (this.orderInfo.status) {
        case 1:
          return '订单已创建，请完成支付后系统派单'
        case 2:
          return '等待跑腿员接单中...'
        case 3:
          return '跑腿员服务中，请保持电话畅通'
        case 4:
          return '订单已完成，感谢使用'
        case 5:
          return '订单已取消'
        default:
          return ''
      }
    },

    getProgressWidth(): string {
      if (this.orderInfo.status === 5) return '0%'
      const percentages = [0, 0, 33, 66, 100]
      return (percentages[this.orderInfo.status] ?? 0) + '%'
    },

    isStepActive(index: number): boolean {
      return this.orderInfo.status > index
    },

    isStepCurrent(index: number): boolean {
      return this.orderInfo.status === index + 1
    },

    getPaymentMethodText(): string {
      return this.orderInfo.paymentMethod === 1 ? '微信支付' : '银行卡支付'
    },

    formatMoney(v: any): string {
      const n = Number(v)
      if (Number.isFinite(n)) return n.toFixed(2)
      return '0.00'
    },

    formatDistance(v: any): string {
      const n = Number(v)
      if (Number.isFinite(n)) return n.toFixed(2)
      return '0.00'
    },

    formatTime(time: string): string {
      if (!time) return ''
      return time.replace('T', ' ').substring(0, 19)
    },

    callRunner() {
      if (this.orderInfo.runnerPhone) {
        uni.makePhoneCall({
          phoneNumber: this.orderInfo.runnerPhone
        })
        this.closePhoneModal()
      }
    },

    handleContactRunner() {
      this.showContactModal = true
    },

    closeContactModal() {
      this.showContactModal = false
    },

    closePhoneModal() {
      this.showPhoneModal = false
    },

    handlePhoneContact() {
      this.closeContactModal()
      this.showPhoneModal = true
    },

    handleOnlineContact() {
      this.closeContactModal()
      if (!this.orderInfo.id) {
        uni.showToast({
          title: '订单信息缺失',
          icon: 'none'
        })
        return
      }
      uni.navigateTo({
        url: `/subpkg/chat-session?orderId=${this.orderInfo.id}`
      })
    },

    previewImages(startIndex: number) {
      if (!this.imageList.length) return
      uni.previewImage({
        current: this.imageList[startIndex],
        urls: this.imageList
      })
    },

    // 预览评价图片
    previewEvaluationImages(startIndex: number) {
      if (!this.evaluationImageList.length) return
      uni.previewImage({
        current: this.evaluationImageList[startIndex],
        urls: this.evaluationImageList
      })
    },

    async handlePay() {
      try {
        await payOrder(this.orderId)
        uni.showToast({
          title: '支付成功（模拟）',
          icon: 'success'
        })
        setTimeout(() => {
          this.loadOrderDetail()
        }, 800)
      } catch (error) {
        console.error('支付失败:', error)
        uni.showToast({
          title: '支付失败',
          icon: 'none'
        })
      }
    },

    handleCancel() {
      const content =
        this.orderInfo.status === 2
          ? '订单已支付，取消后将为你申请退款，确定要取消吗？'
          : '确定要取消订单吗？'

      uni.showModal({
        title: '提示',
        content,
        success: async (res) => {
          if (res.confirm) {
            try {
              await cancelOrder(this.orderId, '用户取消')
              uni.showToast({
                title: '订单已取消',
                icon: 'success'
              })
              setTimeout(() => {
                this.loadOrderDetail()
              }, 1500)
            } catch (error) {
              console.error('取消订单失败:', error)
              uni.showToast({
                title: '取消失败',
                icon: 'none'
              })
            }
          }
        }
      })
    },

    async handleAcceptOrder() {
      // 检查是否被拉黑
      if (this.orderInfo.blacklisted) {
        uni.showToast({
          title: '您已被该用户拉黑，无法接此订单',
          icon: 'none',
          duration: 2500
        })
        return
      }

      // 检查跑腿员认证状态
      try {
        const authInfo = await getRunnerAuthInfo()
        
        // 如果没有认证信息，提示去认证
        if (!authInfo) {
          uni.showModal({
            title: '提示',
            content: '您还没有完成跑腿员认证，请先完成认证后才能接单',
            showCancel: true,
            confirmText: '去认证',
            cancelText: '取消',
            success: (res) => {
              if (res.confirm) {
                uni.navigateTo({
                  url: '/pages/runner/auth-apply'
                })
              }
            }
          })
          return
        }

        // 检查认证状态：1-待审核，2-已通过，3-已驳回
        if (authInfo.certStatus === 1) {
          uni.showModal({
            title: '提示',
            content: '您的认证申请正在审核中，审核通过后才能接单',
            showCancel: false,
            confirmText: '查看状态',
            success: (res) => {
              if (res.confirm) {
                uni.navigateTo({
                  url: '/pages/runner/auth-status'
                })
              }
            }
          })
          return
        }

        if (authInfo.certStatus === 3) {
          uni.showModal({
            title: '提示',
            content: '您的认证申请未通过，请重新申请认证后才能接单',
            showCancel: true,
            confirmText: '重新申请',
            cancelText: '取消',
            success: (res) => {
              if (res.confirm) {
                uni.navigateTo({
                  url: '/pages/runner/auth-apply'
                })
              }
            }
          })
          return
        }

        // 如果认证状态不是已认证（2），提示去认证
        if (authInfo.certStatus !== 2) {
          uni.showModal({
            title: '提示',
            content: '您还没有完成跑腿员认证，请先完成认证后才能接单',
            showCancel: true,
            confirmText: '去认证',
            cancelText: '取消',
            success: (res) => {
              if (res.confirm) {
                uni.navigateTo({
                  url: '/pages/runner/auth-apply'
                })
              }
            }
          })
          return
        }

        // 认证通过，可以接单
        uni.showModal({
          title: '确认接单',
          content: `确定要接这个订单吗？跑腿收益：¥${this.orderInfo.runnerFee ? this.orderInfo.runnerFee.toFixed(2) : '0.00'}`,
          success: async (res) => {
            if (res.confirm) {
              try {
                await acceptOrder(this.orderId)
                uni.showToast({
                  title: '接单成功',
                  icon: 'success'
                })
                setTimeout(() => {
                  this.loadOrderDetail()
                }, 1500)
              } catch (error) {
                console.error('接单失败:', error)
                uni.showToast({
                  title: '接单失败，请重试',
                  icon: 'none'
                })
              }
            }
          }
        })
      } catch (error) {
        console.error('获取认证信息失败:', error)
        uni.showToast({
          title: '获取认证信息失败，请重试',
          icon: 'none'
        })
      }
    },

    // 跑腿员端从订单详情页进入确认收货
    goConfirmReceive() {
      if (!this.orderInfo.id) return
      uni.navigateTo({
        url: `/pages/runner/confirm-receive?orderId=${this.orderInfo.id}`
      })
    },

    // 订单详情中跳转评价页（下单用户）
    goEvaluateFromDetail() {
      if (!this.orderInfo.id || !this.isOrderOwner) return
      uni.navigateTo({
        url: `/subpkg/order-evaluate?orderId=${this.orderInfo.id}`
      })
    },

    // 跳转到跑腿员详情页
    goRunnerProfile() {
      if (!this.orderInfo.runnerId) return
      uni.navigateTo({
        url: `/subpkg/runner-profile?runnerUserId=${this.orderInfo.runnerId}`
      })
    },

    fetchRoute() {
      if (!this.hasValidCoordinates) return
      const key = MAP_CONFIG.amapKey
      if (!key) return
      const origin = `${this.pickupLng},${this.pickupLat}`
      const destination = `${this.deliveryLng},${this.deliveryLat}`
      uni.request({
        url: 'https://restapi.amap.com/v3/direction/driving',
        method: 'GET',
        data: {
          origin: origin,
          destination: destination,
          key: key,
          extensions: 'base'
        },
        success: (res: any) => {
          if (res.data && res.data.status === '1' && res.data.route) {
            const route = res.data.route
            const paths = route.paths
            if (paths && paths.length > 0) {
              const path = paths[0]
              const steps = path.steps
              if (steps && steps.length > 0) {
                const points: Array<{ latitude: number; longitude: number }> = []
                for (let i = 0; i < steps.length; i++) {
                  const polylineStr = steps[i].polyline
                  if (polylineStr) {
                    const pairs = polylineStr.split(';')
                    for (let j = 0; j < pairs.length; j++) {
                      const parts = pairs[j].split(',')
                      if (parts.length >= 2) {
                        const lng = parseFloat(parts[0])
                        const lat = parseFloat(parts[1])
                        if (!isNaN(lat) && !isNaN(lng)) {
                          points.push({ latitude: lat, longitude: lng })
                        }
                      }
                    }
                  }
                }
                if (points.length >= 2) {
                  this.routePoints = points
                }
              }
            }
          }
        },
        fail: (err) => {
          console.error('路线规划请求失败:', err)
        }
      })
    },

    fitMapView() {
      if (!this.hasValidCoordinates) return
      setTimeout(() => {
        const mapContext = uni.createMapContext('orderMap', this)
        mapContext.includePoints({
          points: [
            { latitude: this.pickupLat, longitude: this.pickupLng },
            { latitude: this.deliveryLat, longitude: this.deliveryLng }
          ],
          padding: [80, 80, 80, 80]
        })
      }, 500)
    },

    onMarkerTap(e: any) {
      const markerId = e.detail?.markerId ?? e.markerId
      if (markerId === 1) {
        uni.openLocation({
          latitude: this.pickupLat,
          longitude: this.pickupLng,
          name: '取件点',
          address: this.orderInfo.pickupAddress || ''
        })
      } else if (markerId === 2) {
        uni.openLocation({
          latitude: this.deliveryLat,
          longitude: this.deliveryLng,
          name: '送达点',
          address: this.orderInfo.deliveryAddress || ''
        })
      }
    }
  }
}
</script>

