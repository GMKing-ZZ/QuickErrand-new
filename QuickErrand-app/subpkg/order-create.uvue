  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.15);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 64rpx;
  display: block;
  text-align: center;
  margin: 0;
  padding: 0;
  height: 64rpx;
  width: 100%;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  z-index: 10;
  white-space: nowrap;
}

.placeholder {
  width: 64rpx;
  flex-shrink: 0;
  margin-left: auto;
}

/* 订单内容 */
.order-content {
  padding: 30rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 地址卡片 */
.address-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
  transition: all 0.3s;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.address-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.12);
}

.address-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.address-header {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.contact-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.contact-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-phone {
  font-size: 28rpx;
  color: #666666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.default-tag {
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}

.default-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

.address-detail {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.6;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.address-placeholder {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  flex-wrap: nowrap;
  white-space: nowrap;
  width: 100%;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
  white-space: nowrap;
  flex-shrink: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.arrow-icon {
  font-size: 40rpx;
  color: #cccccc;
  flex-shrink: 0;
  margin-left: 20rpx;
  line-height: 1;
}

.address-info .arrow-icon {
  margin-left: 20rpx;
  align-self: center;
}

.picker-view .arrow-icon {
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 地址表单 */
.address-form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
