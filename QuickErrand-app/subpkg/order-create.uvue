<template>
  <view class="create-order-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">{{ navTitle }}</text>
      <view class="placeholder"></view>
    </view>

    <!-- 订单信息 -->
    <view class="order-content">
      <!-- 取件地址 -->
      <view class="section">
        <view class="section-title">
          <text class="title-text">取件地址</text>
        </view>
        <view class="address-form-card">
          <view class="form-item">
            <text class="form-label">联系人</text>
            <input
              class="form-input"
              v-model="pickupForm.contactName"
              placeholder="请输入联系人姓名"
              maxlength="20"
            />
          </view>
          <view class="form-item">
            <text class="form-label">联系电话</text>
            <input
              class="form-input"
              v-model="pickupForm.contactPhone"
              placeholder="请输入联系电话"
              type="number"
              maxlength="11"
            />
          </view>
          <view class="form-item">
            <text class="form-label">所在地区</text>
            <picker
              mode="region"
              :value="pickupForm.region"
              @change="onPickupRegionChange"
            >
              <view class="picker-view">
                <text v-if="pickupForm.province" class="picker-text">
                  {{ pickupForm.province }} {{ pickupForm.city }} {{ pickupForm.district }}
                </text>
                <text v-else class="picker-placeholder">请选择省市区</text>
                <text class="arrow-icon">›</text>
              </view>
            </picker>
          </view>
          <view class="form-item">
            <text class="form-label">详细地址</text>
            <textarea
              class="form-textarea"
              v-model="pickupForm.detailAddress"
              placeholder="请输入详细地址"
              maxlength="200"
            ></textarea>
          </view>
          <view class="form-item" @click="choosePickupLocation">
            <text class="form-label">选择位置</text>
            <view class="picker-view">
              <text v-if="pickupForm.latitude && pickupForm.longitude" class="picker-text">
                已选择位置
              </text>
              <text v-else class="picker-placeholder">点击选择地图位置</text>
              <text class="arrow-icon">›</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 送达地址 -->
      <view class="section">
        <view class="section-title">
          <text class="title-text">送达地址</text>
        </view>
        <view class="address-card" @click="selectDeliveryAddress">
          <view v-if="deliveryAddress" class="address-info">
            <view class="address-header">
              <view class="contact-row">
                <text class="contact-name">{{ deliveryAddress.contactName }}</text>
                <text class="contact-phone">{{ deliveryAddress.contactPhone }}</text>
                <view v-if="deliveryAddress.isDefault === 1" class="default-tag">
                  <text class="default-text">默认</text>
                </view>
              </view>
              <text class="address-detail">
                {{ deliveryAddress.province }} {{ deliveryAddress.city }} {{ deliveryAddress.district }} {{ deliveryAddress.detailAddress }}
              </text>
            </view>
            <text class="arrow-icon">›</text>
          </view>
          <view v-else class="address-placeholder">
            <text class="placeholder-text">请选择送达地址</text>
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>

      <!-- 距离和费用 -->
      <view v-if="isPickupFormValid() && deliveryAddress" class="fee-section">
        <view class="fee-item">
          <text class="fee-label">配送距离</text>
          <text class="fee-value">{{ distance.toFixed(2) }} km</text>
        </view>
        <view class="fee-item">
          <text class="fee-label">配送费用</text>
          <text class="fee-value price">¥{{ totalFee.toFixed(2) }}</text>
        </view>
        <view class="fee-item custom-amount-item">
          <text class="fee-label">自定义金额</text>
          <view class="custom-amount-input-wrapper">
            <text class="currency-symbol">¥</text>
            <input
              class="custom-amount-input"
              type="digit"
              v-model="customAmount"
              placeholder="0.00"
              @input="onCustomAmountChange"
            />
          </view>
        </view>
      </view>

      <!-- 物品信息 -->
      <view class="section">
        <view class="section-title">
          <text class="title-text">物品信息</text>
        </view>
        <view class="item-info-card">
          <view class="form-item">
            <text class="form-label">物品描述</text>
            <textarea
              class="form-textarea"
              v-model="itemDescription"
              placeholder="请输入物品描述（选填）"
              maxlength="500"
            ></textarea>
            <text class="char-count">{{ itemDescription.length }}/500</text>
          </view>
          <view class="form-item">
            <text class="form-label">物品图片</text>
            <view class="image-upload-container">
              <view class="image-list">
                <view
                  v-for="(image, index) in itemImages"
                  :key="index"
                  class="image-item"
                >
                  <image
                    class="uploaded-image"
                    :src="image"
                    mode="aspectFill"
                    @click="previewImage(index)"
                  ></image>
                  <view class="delete-btn" @click="deleteImage(index)">
                    <text class="delete-icon">×</text>
                  </view>
                </view>
                <view
                  v-if="itemImages.length < 9"
                  class="upload-btn"
                  @click="chooseImage"
                >
                  <text class="upload-icon">+</text>
                  <text class="upload-text">上传图片</text>
                </view>
              </view>
              <text class="upload-tip">最多上传9张图片（选填）</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="section">
        <view class="section-title">
          <text class="title-text">备注信息</text>
        </view>
        <view class="remark-card">
          <textarea
            class="remark-input"
            v-model="remark"
            placeholder="请输入备注信息（选填）"
            maxlength="200"
          ></textarea>
          <text class="char-count">{{ remark.length }}/200</text>
        </view>
      </view>

      <!-- 支付方式 -->
      <view class="section">
        <view class="section-title">
          <text class="title-icon">💳</text>
          <text class="title-text">支付方式</text>
        </view>
        <view class="payment-methods">
          <view
            class="payment-item"
            :class="{ active: paymentMethod === 1 }"
            @click="selectPaymentMethod(1)"
          >
            <view class="payment-left">
              <image class="payment-icon" src="/static/weixinzhifu.png" mode="aspectFit"></image>
              <text class="payment-name">微信支付</text>
            </view>
            <view class="radio" :class="{ checked: paymentMethod === 1 }"></view>
          </view>
          <view
            class="payment-item"
            :class="{ active: paymentMethod === 2 }"
            @click="selectPaymentMethod(2)"
          >
            <view class="payment-left">
              <image class="payment-icon" src="/static/yinlian.png" mode="aspectFit"></image>
              <text class="payment-name">银行卡支付</text>
            </view>
            <view class="radio" :class="{ checked: paymentMethod === 2 }"></view>
          </view>
        </view>
      </view>

      <!-- 收货码设置 -->
      <view class="section">
        <view class="section-title">
          <text class="title-icon">🔐</text>
          <text class="title-text">收货码</text>
        </view>
        <view class="pickup-code-card">
          <view class="pickup-code-info">
            <text class="pickup-code-label">开启收货码</text>
            <text class="pickup-code-desc">开启后，跑腿员送达时需要输入收货码才能完成订单</text>
          </view>
          <switch :checked="enablePickupCode" @change="onPickupCodeChange" color="#2563eb" />
        </view>
      </view>
    </view>

    <!-- 底部提交按钮 -->
    <view class="submit-section">
      <view class="price-info">
        <text class="price-label">实付金额</text>
        <text class="price-amount">¥{{ getFinalAmount().toFixed(2) }}</text>
      </view>
      <button class="submit-btn" @click="handleSubmit" :loading="submitting">
        <text class="btn-text">立即下单</text>
      </button>
    </view>
  </view>
</template>

<script>
import { getOrderTypes, calculateFee, createOrder } from '@/common/api/order.uts'
import type { OrderTypeInfo, CreateOrderParams } from '@/common/api/order.uts'
import type { AddressInfo } from '@/common/api/address.uts'
import { getAddressList } from '@/common/api/address.uts'
import { getUserInfo } from '@/common/api/user.uts'
import { MAP_CONFIG } from '@/common/config/map.uts'
import { upload } from '@/common/utils/request.uts'

export default {
  data() {
    return {
      orderTypeId: 0,
      orderTypeName: '',
      orderType: null as OrderTypeInfo | null,
      navTitle: '下单',
      pickupForm: {
        contactName: '',
        contactPhone: '',
        province: '',
        city: '',
        district: '',
        detailAddress: '',
        region: [] as string[],
        latitude: '',
        longitude: ''
      },
      deliveryAddress: null as AddressInfo | null,
      distance: 0,
      totalFee: 0,
      customAmount: '0',
      itemDescription: '',
      itemImages: [] as string[],
      remark: '',
      paymentMethod: 1,
      enablePickupCode: true,
      submitting: false
    }
  },
  onLoad(options) {
    if (options.orderTypeId) {
      this.orderTypeId = parseInt(options.orderTypeId)
      this.loadOrderType()
    }
    // 加载默认地址
    this.loadDefaultAddress()
    // 加载用户收货码默认设置
    this.loadUserPickupCodeSetting()
    // 监听地址选择事件（在onLoad中设置，确保页面加载时就监听）
    uni.$on('addressSelected', this.handleAddressSelected)
  },
  onShow() {
    // 确保事件监听器存在（防止被移除后未重新绑定）
    uni.$off('addressSelected', this.handleAddressSelected)
    uni.$on('addressSelected', this.handleAddressSelected)
  },
  onUnload() {
    // 页面卸载时移除事件监听
    uni.$off('addressSelected', this.handleAddressSelected)
  },
  methods: {
    async loadOrderType() {
      try {
        console.log('开始加载订单类型, orderTypeId:', this.orderTypeId)
        const types = await getOrderTypes()
        console.log('获取到的订单类型列表:', types)
        this.orderType = types.find((item: OrderTypeInfo) => item.id === this.orderTypeId) || null
        console.log('找到的订单类型:', this.orderType)
        if (this.orderType) {
          this.orderTypeName = this.orderType.typeName
          this.totalFee = this.orderType.basePrice || 0
          // 更新导航标题
          if (this.orderType.typeName && this.orderType.typeName !== '下单') {
            this.navTitle = `${this.orderType.typeName}下单`
          } else {
            this.navTitle = '下单'
          }
          console.log('设置 orderTypeName:', this.orderTypeName)
          console.log('更新 navTitle:', this.navTitle)
        } else {
          console.warn('未找到对应的订单类型, orderTypeId:', this.orderTypeId)
          this.navTitle = '下单'
        }
      } catch (error) {
        console.error('获取订单类型失败:', error)
        this.navTitle = '下单'
      }
    },

    async loadDefaultAddress() {
      try {
        const addressList = await getAddressList()
        // 查找默认地址（isDefault === 1）
        const defaultAddress = addressList.find((addr: AddressInfo) => addr.isDefault === 1)
        if (defaultAddress) {
          this.deliveryAddress = defaultAddress
          console.log('已加载默认地址:', defaultAddress)
          // 如果取件地址已填写，计算距离和费用
          if (this.isPickupFormValid()) {
            this.calculateDistance()
          }
        } else {
          console.log('用户没有默认地址')
        }
      } catch (error) {
        console.error('获取默认地址失败:', error)
      }
    },

    async loadUserPickupCodeSetting() {
      try {
        const userInfo = await getUserInfo()
        if (userInfo.pickupCodeEnabled !== null && userInfo.pickupCodeEnabled !== undefined) {
          this.enablePickupCode = userInfo.pickupCodeEnabled === 1
        }
      } catch (error) {
        console.error('获取用户收货码设置失败:', error)
      }
    },

    goBack() {
      uni.navigateBack()
    },

    onPickupRegionChange(e: any) {
      const region = e.detail.value as string[]
      const province = region[0] || ''
      const city = region[1] || ''
      const district = region[2] || ''
      
      // 检查是否为直辖市（北京市、天津市、重庆市、上海市）
      const isMunicipality = province.includes('北京') || province.includes('天津') || 
                             province.includes('重庆') || province.includes('上海')
      
      if (isMunicipality) {
        // 直辖市：省名 = 市名
        this.pickupForm.province = province
        this.pickupForm.city = province
        this.pickupForm.district = district
        this.pickupForm.region = [province, province, district]
      } else {
        // 普通省份
        this.pickupForm.province = province
        this.pickupForm.city = city
        this.pickupForm.district = district
        this.pickupForm.region = region
      }
      
      // 如果送达地址已选择，重新计算距离
      if (this.deliveryAddress && this.isPickupFormValid()) {
        this.calculateDistance()
      }
    },

    isPickupFormValid(): boolean {
      return !!(
        this.pickupForm.contactName &&
        this.pickupForm.contactPhone &&
        this.pickupForm.province &&
        this.pickupForm.city &&
        this.pickupForm.district &&
        this.pickupForm.detailAddress
      )
    },

    getPickupAddress(): AddressInfo | null {
      if (!this.isPickupFormValid()) {
        return null
      }
      return {
        id: 0,
        contactName: this.pickupForm.contactName,
        contactPhone: this.pickupForm.contactPhone,
        province: this.pickupForm.province,
        city: this.pickupForm.city,
        district: this.pickupForm.district,
        detailAddress: this.pickupForm.detailAddress,
        longitude: this.pickupForm.longitude || '',
        latitude: this.pickupForm.latitude || '',
        isDefault: 0,
        createTime: ''
      }
    },

    choosePickupLocation() {
      uni.chooseLocation({
        success: (res) => {
          console.log('选择取件位置成功:', res)
          this.pickupForm.latitude = res.latitude.toString()
          this.pickupForm.longitude = res.longitude.toString()

          if (res.address || res.name) {
            this.parsePickupAddressFromChooseLocation(res)
          } else {
            this.reverseGeocodePickup(res.latitude, res.longitude)
          }

          if (this.deliveryAddress && this.isPickupFormValid()) {
            setTimeout(() => {
              this.calculateDistance()
            }, 100)
          }
        },
        fail: (err) => {
          console.error('选择位置失败:', err)
          if (err.errMsg && !err.errMsg.includes('cancel')) {
            uni.showToast({
              title: '选择位置失败，请重试',
              icon: 'none',
              duration: 2000
            })
          }
        }
      })
    },

    parsePickupAddressFromChooseLocation(locationRes: any) {
      const address = locationRes.address || ''
      const name = locationRes.name || ''

      const key = MAP_CONFIG.amapKey
      if (!key) {
        this.fillPickupAddressFallback(address, name)
        return
      }

      const location = `${locationRes.longitude},${locationRes.latitude}`
      uni.showLoading({ title: '正在解析地址...', mask: true })

      uni.request({
        url: 'https://restapi.amap.com/v3/geocode/regeo',
        method: 'GET',
        data: {
          location: location,
          key: key,
          radius: 1000,
          extensions: 'base'
        },
        success: (res: any) => {
          uni.hideLoading()
          if (res.data && res.data.status === '1' && res.data.regeocode) {
            const addressComponent = res.data.regeocode.addressComponent
            if (addressComponent) {
              const province = addressComponent.province || ''
              let city = addressComponent.city || ''
              const district = addressComponent.district || ''
              const isMunicipality = province.includes('北京') || province.includes('天津') ||
                                     province.includes('重庆') || province.includes('上海')
              if (isMunicipality) {
                this.pickupForm.province = province
                this.pickupForm.city = province
                this.pickupForm.district = district
                this.pickupForm.region = [province, province, district]
              } else {
                this.pickupForm.province = province
                this.pickupForm.city = city
                this.pickupForm.district = district
                this.pickupForm.region = [province, city, district]
              }

              let detailAddr = ''
              if (address && name && address !== name) {
                detailAddr = name + '(' + address + ')'
              } else if (name) {
                detailAddr = name
              } else if (address) {
                detailAddr = address
              }

              if (detailAddr) {
                const prefix = this.pickupForm.province + this.pickupForm.city + this.pickupForm.district
                if (detailAddr.startsWith(prefix)) {
                  detailAddr = detailAddr.substring(prefix.length)
                }
              }

              this.pickupForm.detailAddress = detailAddr || addressComponent.township + addressComponent.street + addressComponent.streetNumber

              uni.showToast({ title: '地址解析成功', icon: 'success', duration: 1500 })
            } else {
              this.fillPickupAddressFallback(address, name)
            }
          } else {
            this.fillPickupAddressFallback(address, name)
          }
        },
        fail: () => {
          uni.hideLoading()
          this.fillPickupAddressFallback(address, name)
        }
      })
    },

    fillPickupAddressFallback(address: string, name: string) {
      if (!address && !name) return
      this.pickupForm.detailAddress = name ? (address && address !== name ? name + '(' + address + ')' : name) : address
    },

    // 逆地理编码：根据经纬度获取取件地址信息
    reverseGeocodePickup(latitude: number, longitude: number) {
      // 使用高德地图逆地理编码API
      uni.showLoading({
        title: '正在解析地址...',
        mask: true
      })
      
      // 高德地图API需要经纬度顺序为：经度,纬度
      const location = `${longitude},${latitude}`
      
      // 从配置文件中获取高德地图key
      const key = MAP_CONFIG.amapKey
      
      if (!key) {
        uni.hideLoading()
        uni.showToast({
          title: '请配置高德地图Key',
          icon: 'none',
          duration: 2000
        })
        console.warn('高德地图Key未配置，请在manifest.json中配置web.sdkConfigs.maps.amap.key')
        return
      }
      
      uni.request({
        url: 'https://restapi.amap.com/v3/geocode/regeo',
        method: 'GET',
        data: {
          location: location,
          key: key,
          radius: 1000,
          extensions: 'base'
        },
        success: (res: any) => {
          console.log('取件地址高德地图逆地理编码结果:', res)
          uni.hideLoading()
          
          if (res.data && res.data.status === '1' && res.data.regeocode) {
            const regeocode = res.data.regeocode
            this.parsePickupAddressFromAmapGeocode(regeocode)
          } else {
            console.warn('取件地址逆地理编码失败:', res.data)
            uni.showToast({
              title: res.data?.info || '地址解析失败',
              icon: 'none',
              duration: 2000
            })
          }
        },
        fail: (err) => {
          console.error('取件地址逆地理编码请求失败:', err)
          uni.hideLoading()
          uni.showToast({
            title: '网络错误，请检查网络',
            icon: 'none',
            duration: 2000
          })
        }
      })
    },

    // 解析高德地图逆地理编码返回的取件地址信息
    parsePickupAddressFromAmapGeocode(regeocode: any) {
      console.log('解析取件地址高德地图逆地理编码结果:', regeocode)
      
      if (!regeocode) {
        return
      }

      const addressComponent = regeocode.addressComponent
      if (addressComponent) {
        // 处理直辖市（北京市、天津市、重庆市、上海市）
        const province = addressComponent.province || ''
        let city = addressComponent.city || ''
        const district = addressComponent.district || ''
        
        // 检查是否为直辖市
        const isMunicipality = province.includes('北京') || province.includes('天津') || 
                               province.includes('重庆') || province.includes('上海')
        
        if (isMunicipality) {
          // 直辖市：省名 = 市名
          this.pickupForm.province = province
          this.pickupForm.city = province  // 市名与省名相同
          this.pickupForm.district = district
          
          // 更新region用于picker显示
          this.pickupForm.region = [province, province, district]
        } else {
          // 普通省份
          this.pickupForm.province = province
          this.pickupForm.city = city
          this.pickupForm.district = district
          
          // 更新region用于picker显示（使用完整名称）
          this.pickupForm.region = [province, city, district]
        }
        
        // 设置详细地址
        let detailAddress = ''
        if (regeocode.formatted_address) {
          detailAddress = regeocode.formatted_address
          
          // 去除省市区前缀，只保留详细地址部分
          const province = this.pickupForm.province || ''
          const city = this.pickupForm.city || ''
          const district = this.pickupForm.district || ''
          
          // 去除省市区前缀
          let cleanAddress = detailAddress
          if (province && cleanAddress.startsWith(province)) {
            cleanAddress = cleanAddress.substring(province.length)
          }
          if (city && cleanAddress.startsWith(city)) {
            cleanAddress = cleanAddress.substring(city.length)
          }
          if (district && cleanAddress.startsWith(district)) {
            cleanAddress = cleanAddress.substring(district.length)
          }
          
          // 去除可能的空格和分隔符
          cleanAddress = cleanAddress.trim()
          
          // 如果去除前缀后还有内容，使用去除前缀后的地址；否则使用完整地址
          if (cleanAddress && cleanAddress.length > 0) {
            this.pickupForm.detailAddress = cleanAddress
          } else {
            // 如果去除前缀后为空，尝试从addressComponent拼接详细地址
            const parts: string[] = []
            if (addressComponent.township) {
              parts.push(addressComponent.township)
            }
            if (addressComponent.street) {
              parts.push(addressComponent.street)
            }
            if (addressComponent.streetNumber) {
              parts.push(addressComponent.streetNumber)
            }
            if (addressComponent.building) {
              parts.push(addressComponent.building)
            }
            if (addressComponent.neighborhood) {
              parts.push(addressComponent.neighborhood)
            }
            this.pickupForm.detailAddress = parts.length > 0 ? parts.join('') : detailAddress
          }
        } else {
          // 如果没有formatted_address，从addressComponent拼接详细地址
          const parts: string[] = []
          if (addressComponent.township) {
            parts.push(addressComponent.township)
          }
          if (addressComponent.street) {
            parts.push(addressComponent.street)
          }
          if (addressComponent.streetNumber) {
            parts.push(addressComponent.streetNumber)
          }
          if (addressComponent.building) {
            parts.push(addressComponent.building)
          }
          if (addressComponent.neighborhood) {
            parts.push(addressComponent.neighborhood)
          }
          this.pickupForm.detailAddress = parts.join('')
        }
        
        uni.showToast({
          title: '地址解析成功',
          icon: 'success',
          duration: 1500
        })
      } else if (regeocode.formatted_address) {
        // 如果没有addressComponent，但有formatted_address，尝试解析
        this.parsePickupAddressFromLocation({ address: regeocode.formatted_address })
      }
    },

    parsePickupAddressFromLocation(locationRes: any) {
      if (!locationRes.address) {
        return
      }

      const address = locationRes.address
      console.log('解析取件地址:', address)

      // 使用正则表达式解析省市区
      // 匹配格式：省/市/自治区/特别行政区 + 市/地区/自治州/盟 + 区/县/市/旗 + 详细地址
      const fullMatch = address.match(/^(.+?[省市区县]|.+?自治区|.+?特别行政区)(.+?[市区县]|.+?地区|.+?自治州|.+?盟)?(.+?[区县市]|.+?旗)?(.*)$/)
      
      if (fullMatch) {
        const province = fullMatch[1] || ''
        const city = fullMatch[2] || ''
        const district = fullMatch[3] || ''
        let detailAddress = fullMatch[4] || ''

        // 处理直辖市（北京、上海、天津、重庆）
        if (province && (province.includes('北京') || province.includes('上海') || 
            province.includes('天津') || province.includes('重庆'))) {
          // 直辖市：省名 = 市名
          this.pickupForm.province = province
          this.pickupForm.city = province
          
          // 提取区
          if (district) {
            this.pickupForm.district = district
            this.pickupForm.region = [province, province, district]
          } else if (city && city !== province) {
            // 如果city不是省名，可能是区名
            this.pickupForm.district = city
            this.pickupForm.region = [province, province, city]
            detailAddress = city + detailAddress
          } else {
            this.pickupForm.region = [province, province, '']
          }
        } else {
          // 普通省份
          if (province) {
            this.pickupForm.province = province
          }
          if (city) {
            this.pickupForm.city = city
          }
          if (district) {
            this.pickupForm.district = district
          }
          
          // 更新region用于picker显示
          this.pickupForm.region = [
            this.pickupForm.province || '',
            this.pickupForm.city || '',
            this.pickupForm.district || ''
          ]
        }

        // 设置详细地址
        detailAddress = detailAddress.trim()
        if (detailAddress) {
          // 如果详细地址为空或需要更新，则设置
          if (!this.pickupForm.detailAddress || this.pickupForm.detailAddress === address) {
            this.pickupForm.detailAddress = detailAddress
          }
        } else if (locationRes.name) {
          // 如果没有详细地址，使用位置名称
          this.pickupForm.detailAddress = locationRes.name
        }
      } else {
        // 如果正则匹配失败，尝试简单分割
        // 使用空格或特定字符分割
        const parts = address.split(/[\s省市区县]/)
        if (parts.length >= 3) {
          const provinceName = parts[0] + (address.includes('省') ? '省' : 
                                            address.includes('市') && !address.includes('省') ? '市' : '')
          
          // 检查是否为直辖市
          const isMunicipality = provinceName.includes('北京') || provinceName.includes('天津') || 
                                 provinceName.includes('重庆') || provinceName.includes('上海')
          
          if (isMunicipality) {
            // 直辖市：省名 = 市名
            this.pickupForm.province = provinceName
            this.pickupForm.city = provinceName
            this.pickupForm.district = parts[2] + (address.includes('区') ? '区' : 
                                                 address.includes('县') ? '县' : '')
            this.pickupForm.region = [provinceName, provinceName, this.pickupForm.district]
          } else {
            // 普通省份
            this.pickupForm.province = provinceName
            this.pickupForm.city = parts[1] + '市'
            this.pickupForm.district = parts[2] + (address.includes('区') ? '区' : 
                                                   address.includes('县') ? '县' : '')
            this.pickupForm.region = [this.pickupForm.province, this.pickupForm.city, this.pickupForm.district]
          }
          
          // 剩余部分作为详细地址
          const detailStart = this.pickupForm.province.length + this.pickupForm.city.length + this.pickupForm.district.length
          const remaining = address.substring(detailStart).trim()
          if (remaining && !this.pickupForm.detailAddress) {
            this.pickupForm.detailAddress = remaining
          }
        } else {
          // 如果无法解析，至少填充详细地址
          if (!this.pickupForm.detailAddress) {
            this.pickupForm.detailAddress = address
          }
        }
      }

      // 如果位置名称存在且详细地址为空，使用位置名称
      if (locationRes.name && !this.pickupForm.detailAddress) {
        this.pickupForm.detailAddress = locationRes.name
      }
    },

    selectDeliveryAddress() {
      uni.navigateTo({
        url: '/subpkg/address-list?selectMode=delivery'
      })
    },

    handleAddressSelected(data: any) {
      console.log('handleAddressSelected 被调用, data:', data)
      const { mode, address } = data
      if (mode === 'delivery' && address) {
        console.log('更新送达地址:', address)
        console.log('送达地址经纬度:', {
          latitude: address.latitude,
          longitude: address.longitude
        })
        // 直接赋值，Vue会自动处理响应式更新
        this.deliveryAddress = address
        
        // 使用 setTimeout 确保在下一个事件循环中执行，让视图先更新
        setTimeout(() => {
          // 检查取件地址是否已填写（包括经纬度）
          const hasPickupLocation = this.pickupForm.latitude && this.pickupForm.longitude
          const hasPickupInfo = this.isPickupFormValid()
          
          console.log('地址选择后检查:', {
            hasPickupLocation,
            hasPickupInfo,
            hasDeliveryLocation: address.latitude && address.longitude
          })
          
          // 如果取件地址已填写且有位置信息，计算距离和费用
          if (hasPickupInfo && hasPickupLocation) {
            this.calculateDistance()
          } else if (!hasPickupLocation) {
            console.warn('取件地址尚未选择位置，无法计算距离')
          } else if (!address.latitude || !address.longitude) {
            console.warn('送达地址缺少经纬度信息，无法精确计算距离')
            // 即使没有经纬度，也尝试使用默认距离计算费用
            this.distance = 5.0
            this.calculateFeeAmount()
          }
        }, 100)
      }
    },

    calculateDistance() {
      const pickupAddr = this.getPickupAddress()
      if (!pickupAddr || !this.deliveryAddress) {
        console.log('calculateDistance: 取件地址或送达地址为空', {
          pickupAddr: pickupAddr,
          deliveryAddress: this.deliveryAddress
        })
        return
      }

      const lat1Str = pickupAddr.latitude || ''
      const lon1Str = pickupAddr.longitude || ''
      const lat2Str = this.deliveryAddress.latitude || ''
      const lon2Str = this.deliveryAddress.longitude || ''

      const lat1 = parseFloat(lat1Str)
      const lon1 = parseFloat(lon1Str)
      const lat2 = parseFloat(lat2Str)
      const lon2 = parseFloat(lon2Str)

      const isValidLat1 = !isNaN(lat1) && lat1 !== 0 && lat1Str.trim() !== ''
      const isValidLon1 = !isNaN(lon1) && lon1 !== 0 && lon1Str.trim() !== ''
      const isValidLat2 = !isNaN(lat2) && lat2 !== 0 && lat2Str.trim() !== ''
      const isValidLon2 = !isNaN(lon2) && lon2 !== 0 && lon2Str.trim() !== ''

      if (!isValidLat1 || !isValidLon1 || !isValidLat2 || !isValidLon2) {
        console.warn('calculateDistance: 经纬度无效，使用默认距离')
        this.distance = 5.0
        this.calculateFeeAmount()
        return
      }

      const key = MAP_CONFIG.amapKey
      if (!key) {
        this.distance = this.calculateStraightLineDistance(lat1, lon1, lat2, lon2)
        this.calculateFeeAmount()
        return
      }

      const origin = `${lon1},${lat1}`
      const destination = `${lon2},${lat2}`
      uni.request({
        url: 'https://restapi.amap.com/v3/direction/driving',
        method: 'GET',
        data: {
          origin: origin,
          destination: destination,
          key: key,
          extensions: 'base'
        },
        success: (res: any) => {
          if (res.data && res.data.status === '1' && res.data.route) {
            const paths = res.data.route.paths
            if (paths && paths.length > 0) {
              const distMeters = parseFloat(paths[0].distance || '0')
              if (distMeters > 0) {
                this.distance = distMeters / 1000
                this.calculateFeeAmount()
                return
              }
            }
          }
          this.distance = this.calculateStraightLineDistance(lat1, lon1, lat2, lon2)
          this.calculateFeeAmount()
        },
        fail: () => {
          this.distance = this.calculateStraightLineDistance(lat1, lon1, lat2, lon2)
          this.calculateFeeAmount()
        }
      })
    },

    calculateStraightLineDistance(lat1: number, lon1: number, lat2: number, lon2: number): number {
      const R = 6371
      const dLat = this.toRad(lat2 - lat1)
      const dLon = this.toRad(lon2 - lon1)
      const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(this.toRad(lat1)) * Math.cos(this.toRad(lat2)) *
        Math.sin(dLon / 2) * Math.sin(dLon / 2)
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a))
      return R * c
    },

    toRad(value: number): number {
      return value * Math.PI / 180
    },

    async calculateFeeAmount() {
      try {
        const fee = await calculateFee({
          orderTypeId: this.orderTypeId,
          distance: this.distance
        })
        this.totalFee = fee
        // 自动填充自定义金额为计算出的费用
        this.customAmount = fee.toFixed(2)
      } catch (error) {
        console.error('计算费用失败:', error)
        // 使用本地计算作为备选
        if (this.orderType) {
          this.totalFee = this.orderType.basePrice + this.orderType.pricePerKm * this.distance
          // 自动填充自定义金额为计算出的费用
          this.customAmount = this.totalFee.toFixed(2)
        }
      }
    },

    onCustomAmountChange(e: any) {
      // 用户修改自定义金额时的处理
      let value = e.detail?.value || this.customAmount || ''
      // 移除非数字字符（除了小数点）
      value = value.replace(/[^\d.]/g, '')
      // 确保只有一个小数点
      const parts = value.split('.')
      if (parts.length > 2) {
        value = parts[0] + '.' + parts.slice(1).join('')
      }
      // 限制小数位数为2位
      if (parts.length === 2 && parts[1].length > 2) {
        value = parts[0] + '.' + parts[1].substring(0, 2)
      }
      // 如果为空或只有小数点，设置为0
      if (value === '' || value === '.') {
        value = '0'
      }
      // 如果以0开头但不是0.xx格式，处理前导0
      if (value.length > 1 && value[0] === '0' && value[1] !== '.') {
        value = value.substring(1)
      }
      this.customAmount = value
    },

    getFinalAmount(): number {
      // 获取最终金额：如果用户修改了自定义金额且大于0，使用自定义金额；否则使用计算出的费用
      const custom = parseFloat(this.customAmount)
      if (!isNaN(custom) && custom > 0) {
        return custom
      }
      // 如果自定义金额为0或无效，使用计算出的费用
      return this.totalFee > 0 ? this.totalFee : 0
    },

    selectPaymentMethod(method: number) {
      this.paymentMethod = method
    },

    onPickupCodeChange(e: any) {
      this.enablePickupCode = e.detail.value
    },

    chooseImage() {
      const maxCount = 9 - this.itemImages.length
      if (maxCount <= 0) {
        uni.showToast({
          title: '最多上传9张图片',
          icon: 'none'
        })
        return
      }

      uni.chooseImage({
        count: maxCount,
        sizeType: ['compressed'],
        sourceType: ['album', 'camera'],
        success: (res) => {
          console.log('选择图片成功:', res)
          // 上传图片到服务器
          this.uploadImages(res.tempFilePaths)
        },
        fail: (err) => {
          console.error('选择图片失败:', err)
          if (err.errMsg && !err.errMsg.includes('cancel')) {
            uni.showToast({
              title: '选择图片失败',
              icon: 'none'
            })
          }
        }
      })
    },

    async uploadImages(tempFilePaths: string[]) {
      uni.showLoading({
        title: '上传中...',
        mask: true
      })

      try {
        const uploadPromises = tempFilePaths.map((tempFilePath) => {
          return new Promise<string>((resolve, reject) => {
            upload('/file/upload/order-item', tempFilePath, {})
              .then((url: string) => {
                resolve(url)
              })
              .catch((err: any) => {
                console.error('图片上传失败:', err)
                reject(err)
              })
          })
        })

        const uploadedUrls = await Promise.all(uploadPromises)
        this.itemImages.push(...uploadedUrls)
        console.log('图片上传完成:', this.itemImages)
      } catch (error) {
        console.error('上传图片失败:', error)
        uni.showToast({
          title: '上传图片失败',
          icon: 'none'
        })
      } finally {
        uni.hideLoading()
      }
    },

    deleteImage(index: number) {
      this.itemImages.splice(index, 1)
    },

    previewImage(index: number) {
      uni.previewImage({
        urls: this.itemImages,
        current: index
      })
    },

    async handleSubmit() {
      // 验证取件地址
      if (!this.pickupForm.contactName) {
        uni.showToast({
          title: '请输入联系人姓名',
          icon: 'none'
        })
        return
      }
      if (!this.pickupForm.contactPhone) {
        uni.showToast({
          title: '请输入联系电话',
          icon: 'none'
        })
        return
      }
      if (!this.pickupForm.province || !this.pickupForm.city || !this.pickupForm.district) {
        uni.showToast({
          title: '请选择所在地区',
          icon: 'none'
        })
        return
      }
      if (!this.pickupForm.detailAddress) {
        uni.showToast({
          title: '请输入详细地址',
          icon: 'none'
        })
        return
      }

      if (!this.deliveryAddress) {
        uni.showToast({
          title: '请选择送达地址',
          icon: 'none'
        })
        return
      }

      // 验证取件地址经纬度（数据库要求必填）
      if (!this.pickupForm.longitude || !this.pickupForm.latitude) {
        uni.showToast({
          title: '请选择取件位置',
          icon: 'none'
        })
        return
      }

      // 验证送达地址经纬度（数据库要求必填）
      if (!this.deliveryAddress.longitude || !this.deliveryAddress.latitude) {
        uni.showToast({
          title: '送达地址缺少位置信息，请重新选择',
          icon: 'none'
        })
        return
      }

      this.submitting = true
      try {
        const pickupAddr = this.getPickupAddress()
        if (!pickupAddr) {
          uni.showToast({
            title: '取件地址信息不完整',
            icon: 'none'
          })
          this.submitting = false
          return
        }

        // 获取最终金额
        const finalAmount = this.getFinalAmount()
        
        // 创建订单
        const orderData: CreateOrderParams = {
          orderTypeId: this.orderTypeId,
          pickupAddressId: 0, // 取件地址是临时填写的，没有ID
          deliveryAddressId: this.deliveryAddress.id,
          pickupContact: pickupAddr.contactName,
          pickupPhone: pickupAddr.contactPhone,
          pickupAddress: `${pickupAddr.province}${pickupAddr.city}${pickupAddr.district}${pickupAddr.detailAddress}`,
          pickupLongitude: pickupAddr.longitude || '',
          pickupLatitude: pickupAddr.latitude || '',
          deliveryContact: this.deliveryAddress.contactName,
          deliveryPhone: this.deliveryAddress.contactPhone,
          deliveryAddress: `${this.deliveryAddress.province}${this.deliveryAddress.city}${this.deliveryAddress.district}${this.deliveryAddress.detailAddress}`,
          deliveryLongitude: this.deliveryAddress.longitude || '',
          deliveryLatitude: this.deliveryAddress.latitude || '',
          distance: this.distance || 0,
          itemDescription: this.itemDescription && this.itemDescription.trim() ? this.itemDescription.trim() : '',
          itemImages: this.itemImages.length > 0 ? JSON.stringify(this.itemImages) : undefined,
          customAmount: finalAmount > 0 ? finalAmount : undefined,
          remark: this.remark,
          paymentMethod: this.paymentMethod,
          enablePickupCode: this.enablePickupCode
        }

        const orderId = await createOrder(orderData)

        // 下单成功：仅创建订单，跳转到订单详情页（由详情页进行“立即支付”）
        uni.showToast({
          title: '下单成功',
          icon: 'success'
        })
        setTimeout(() => {
          uni.redirectTo({
            url: `/subpkg/order-detail?orderId=${orderId}`
          })
        }, 800)
      } catch (error) {
        console.error('下单失败:', error)
        uni.showToast({
          title: '下单失败，请重试',
          icon: 'none'
        })
      } finally {
        this.submitting = false
      }
    },
  }
}
</script>

<style scoped>
.create-order-container {
  min-height: 100vh;
  background: #f9fafb;
  padding-bottom: 200rpx;
}

/* 导航栏 */
